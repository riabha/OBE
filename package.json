{
  "name": "quest-obe-portal",
  "version": "1.0.1",
  "description": "QUEST OBE Portal - Outcome-Based Education Management System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "init-db": "node scripts/init-platform-database.js",
    "seed-demo": "node scripts/seed-demo-university.js --reset",
    "seed-quest": "node scripts/seed-quest-university.js --import=scripts/data/quest-scraped.json --reset --db=obe_quest",
    "seed-quest-live": "node scripts/seed-quest-university.js --reset --db=obe_quest",
    "scrape-quest": "node scripts/seed-quest-university.js --scrape-only",
    "validate-quest": "node scripts/validate-quest-data.js",
    "deploy": "powershell -ExecutionPolicy Bypass -File deploy.ps1"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.19.1",
    "multer": "^2.0.2",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0"
  },
  "overrides": {
    "validator": "13.15.15"
  }
}
